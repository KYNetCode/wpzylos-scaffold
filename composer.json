{
  "name": "kynetcode/wpzylos-scaffold",
  "version": "1.0.0",
  "description": "Template repository for creating production-ready WPZylos-based WordPress plugins with MVC architecture, dependency injection, and PHP-Scoper namespace isolation",
  "type": "wordpress-plugin",
  "license": "GPL-2.0-or-later",
  "keywords": [
    "wordpress",
    "wpzylos",
    "plugin",
    "scaffold",
    "template",
    "boilerplate",
    "mvc",
    "php-scoper",
    "dependency-injection",
    "psr-4"
  ],
  "homepage": "https://github.com/KYNetCode/wpzylos-scaffold",
  "authors": [
    {
      "name": "KYNetCode",
      "email": "diggerwp@gmail.com",
      "homepage": "https://github.com/KYNetCode",
      "role": "Developer"
    }
  ],
  "support": {
    "issues": "https://github.com/KYNetCode/wpzylos-scaffold/issues",
    "source": "https://github.com/KYNetCode/wpzylos-scaffold",
    "docs": "https://wpzylos.com"
  },
  "require": {
    "php": "^8.0",
    "kynetcode/wpzylos-config": "^1.0",
    "kynetcode/wpzylos-container": "^1.0",
    "kynetcode/wpzylos-core": "^1.0",
    "kynetcode/wpzylos-database": "^1.0",
    "kynetcode/wpzylos-hooks": "^1.0",
    "kynetcode/wpzylos-http": "^1.0",
    "kynetcode/wpzylos-i18n": "^1.0",
    "kynetcode/wpzylos-migrations": "^1.0",
    "kynetcode/wpzylos-routing": "^1.0",
    "kynetcode/wpzylos-security": "^1.0",
    "kynetcode/wpzylos-validation": "^1.0",
    "kynetcode/wpzylos-views": "^1.0"
  },
  "require-dev": {
    "humbug/php-scoper": "^0.18",
    "kynetcode/wpzylos-cli-devtool": "*",
    "phpstan/phpstan": "^1.10",
    "phpunit/phpunit": "^9.6 || ^10.0",
    "squizlabs/php_codesniffer": "^3.7",
    "symfony/var-dumper": "^7.4",
    "szepeviktor/phpstan-wordpress": "^1.3"
  },
  "autoload": {
    "psr-4": {
      "MyPlugin\\": "app/"
    },
    "files": [
      "app/Support/helpers.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "MyPlugin\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "phpunit",
    "analyze": "phpstan analyze app",
    "cs": "phpcs --standard=PSR12 app",
    "cs-fix": "phpcbf --standard=PSR12 app",
    "qa": [
      "@cs",
      "@analyze",
      "@test"
    ]
  },
  "extra": {
    "installer-name": "my-plugin"
  },
  "config": {
    "sort-packages": true,
    "allow-plugins": {
      "dealerdirect/phpcodesniffer-composer-installer": true
    }
  },
  "minimum-stability": "stable",
  "prefer-stable": true,
  "funding": [
    {
      "type": "paypal",
      "url": "https://www.paypal.com/donate/?hosted_button_id=66U4L3HG4TLCC"
    }
  ]
}
